!ios/
!ios/**
!ios/.gitignore
!macos/
!macos/**
!macos/.gitignore
!linux/
!linux/**
!linux/.gitignore
!windows/
!windows/**
!windows/.gitignore

# Re-exclude generated / local / IDE noise under allowed trees
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/build/
**/.pub-cache/
**/.pub/
**/doc/api/
**/.idea/
**/*.iml
**/.vscode/
**/.DS_Store
**/*.class
**/*.log
**/*.pyc
**/*.swp
**/local.properties
**/GeneratedPluginRegistrant.*
**/ephemeral/
**/Flutter/ephemeral/
**/Flutter/Flutter.podspec
**/.last_build_id
**/app.*.symbols
**/app.*.map.json
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/Pods/
**/DerivedData/
**/.cxx/
**/captures/
**/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.properties
!**/gradlew
!**/gradlew.bat
