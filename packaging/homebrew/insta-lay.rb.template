# Homebrew Cask template for InstaLay.
# Published to amdphreak/homebrew-tap as Casks/insta-lay.rb
# Values for version / sha256 / url are filled by the homebrew workflow on release.
cask "insta-lay" do
  arch arm: "arm64", intel: "x64"

  version "0.1.0"
  sha256 arm:   "REPLACE_ARM_SHA256",
         intel: "REPLACE_INTEL_SHA256"

  url "https://github.com/LinxPhotos/insta-lay/releases/download/v#{version}/InstaLay-#{version}-macos-#{arch}.zip"
  name "InstaLay"
  desc "Batch canvas and tapestry layouts for Instagram aspect ratios"
  homepage "https://github.com/LinxPhotos/insta-lay"

  app "InstaLay.app"

  zap trash: [
    "~/Library/Application Support/insta_lay",
    "~/Library/Preferences/com.linxphotos.instalay.plist",
  ]
end
