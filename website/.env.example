# Stripe Payment Links (static GitHub Pages checkout)
# VITE_STRIPE_PAYMENT_LINK_YEARLY=https://buy.stripe.com/...   # $30 / year
# VITE_STRIPE_PAYMENT_LINK_LIFETIME=https://buy.stripe.com/... # $100 one-time

# Legacy alias for lifetime (still honored)
# VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...

# Optional publishable key if you later embed Elements
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# GitHub Pages base — `/` for app.linx.photos (default). Path prefix only if needed.
# GITHUB_PAGES_BASE=/
