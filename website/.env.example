# Stripe Payment Link URL(s) — see pricing.ts / secrets docs
# VITE_STRIPE_PAYMENT_LINK_YEARLY=https://buy.stripe.com/...
# VITE_STRIPE_PAYMENT_LINK_LIFETIME=https://buy.stripe.com/...
# VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...

# Optional publishable key if you later embed Elements
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Server-only (SolidStart / Worker — not GitHub Pages static)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Adapty (mobile SDK uses --dart-define=ADAPTY_PUBLIC_SDK_KEY=... in Flutter)
# Connect the Adapty Stripe app in Stripe Marketplace; set Checkout/Payment Link
# metadata key customer_user_id (same id the app passes to Adapty.identify).
# Access level id in Adapty dashboard: instalay

# GitHub Pages base — /InstaLay/ for project Pages (must match repo name).
# GITHUB_PAGES_BASE=/InstaLay/
